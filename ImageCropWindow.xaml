<Window x:Class="GhostPaste.ImageCropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="裁切图片"
        Width="760" Height="560"
        MinWidth="520" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="拖动选择要发送给 AI 的区域"
                   Foreground="#DD111827"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1"
                Background="#22000000"
                BorderBrush="#26000000"
                BorderThickness="1"
                CornerRadius="8"
                ClipToBounds="True">
            <Grid x:Name="CropSurface"
                  Background="Transparent"
                  MouseLeftButtonDown="CropSurface_MouseLeftButtonDown"
                  MouseMove="CropSurface_MouseMove"
                  MouseLeftButtonUp="CropSurface_MouseLeftButtonUp">
                <Image x:Name="CropPreviewImage"
                       Stretch="Uniform"
                       SnapsToDevicePixels="True"/>
                <Canvas x:Name="SelectionCanvas"
                        IsHitTestVisible="False">
                    <Rectangle x:Name="SelectionRectangle"
                               Visibility="Collapsed"
                               Stroke="#FF2563EB"
                               StrokeThickness="2"
                               Fill="#302563EB"/>
                </Canvas>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <TextBlock x:Name="SelectionStatusText"
                       Foreground="#99111827"
                       VerticalAlignment="Center"
                       Text="未选择区域时会发送整张图片。"/>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="使用整张"
                        Width="88"
                        Height="32"
                        Margin="0,0,8,0"
                        Click="UseWholeImageButton_Click"/>
                <Button Content="确认裁切"
                        Width="88"
                        Height="32"
                        Margin="0,0,8,0"
                        Click="CropButton_Click"/>
                <Button Content="取消"
                        Width="72"
                        Height="32"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
