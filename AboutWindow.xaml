<Window x:Class="GhostPaste.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About GhostPaste"
        Width="360" Height="240"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="TitleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#99000000"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#18000000"/>
                                <Setter Property="Foreground" Value="#DD000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#26000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12"
            Background="#48FFFFFF"
            BorderBrush="#30000000"
            BorderThickness="1"
            Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent">
                <TextBlock Text="About"
                           Foreground="#DD000000"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Content="X"
                        HorizontalAlignment="Right"
                        Click="CloseButton_Click"
                        Style="{StaticResource TitleButtonStyle}"/>
            </Grid>

            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="GhostPaste"
                           Foreground="#EE000000"
                           FontSize="24"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="CreditLine"
                           Foreground="#AA000000"
                           FontSize="13"
                           Margin="0,8,0,18"
                           HorizontalAlignment="Center"/>
                <Button Click="OpenGitHub_Click"
                        Style="{StaticResource LinkButtonStyle}">
                    <TextBlock x:Name="GitHubLink"
                               Foreground="#CC2563EB"
                               FontSize="13"
                               TextDecorations="Underline"
                               TextWrapping="NoWrap"/>
                </Button>
            </StackPanel>

            <Button Grid.Row="2"
                    Content="Close"
                    HorizontalAlignment="Center"
                    Width="92"
                    Height="32"
                    Click="CloseButton_Click"
                    Foreground="#DD000000"
                    Background="#50FFFFFF"
                    BorderBrush="#24000000"
                    BorderThickness="1"
                    Cursor="Hand"/>
        </Grid>
    </Border>
</Window>
