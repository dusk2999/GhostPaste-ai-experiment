<Window x:Class="GhostPaste.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About GhostPaste"
        Width="460" Height="460"
        MinWidth="430" MinHeight="420"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="TitleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#99000000"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#18000000"/>
                                <Setter Property="Foreground" Value="#DD000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#26000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12"
            Background="#48FFFFFF"
            BorderBrush="#30000000"
            BorderThickness="1"
            Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent">
                <TextBlock Text="About"
                           Foreground="#DD000000"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Content="X"
                        HorizontalAlignment="Right"
                        Click="CloseButton_Click"
                        Style="{StaticResource TitleButtonStyle}"/>
            </Grid>

            <ScrollViewer x:Name="AboutContentScrollViewer"
                          Grid.Row="1"
                          Margin="8,16,8,14"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="GhostPaste"
                               Foreground="#EE000000"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CreditLine"
                               Foreground="#AA000000"
                               FontSize="13"
                               Margin="0,8,0,18"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="说明"
                               Foreground="#DD000000"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBlock x:Name="DescriptionText"
                               Foreground="#BB000000"
                               FontSize="12"
                               LineHeight="19"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="使用说明"
                               Foreground="#DD000000"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,18,0,6"/>
                    <ItemsControl x:Name="UsageList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="#BB000000"
                                           FontSize="12"
                                           LineHeight="20"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,4"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Click="OpenGitHub_Click"
                            Margin="0,18,0,0"
                            Style="{StaticResource LinkButtonStyle}">
                        <TextBlock x:Name="GitHubLink"
                                   Foreground="#CC2563EB"
                                   FontSize="13"
                                   TextDecorations="Underline"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </Button>
                </StackPanel>
            </ScrollViewer>

            <Button Grid.Row="2"
                    Content="Close"
                    HorizontalAlignment="Center"
                    Width="92"
                    Height="32"
                    Click="CloseButton_Click"
                    Foreground="#DD000000"
                    Background="#50FFFFFF"
                    BorderBrush="#24000000"
                    BorderThickness="1"
                    Cursor="Hand"/>
        </Grid>
    </Border>
</Window>
