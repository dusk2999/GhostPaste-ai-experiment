<Window x:Class="GhostPaste.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GhostPaste"
        Width="560" Height="640"
        MinWidth="480" MinHeight="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <SolidColorBrush x:Key="ChromeSurfaceBrush" Color="#40FFFFFF"/>
        <SolidColorBrush x:Key="PanelSurfaceBrush" Color="#60FFFFFF"/>
        <SolidColorBrush x:Key="AnswerSurfaceBrush" Color="#50FFFFFF"/>
        <SolidColorBrush x:Key="ControlSurfaceBrush" Color="#50FFFFFF"/>
        <SolidColorBrush x:Key="ControlHoverBrush" Color="#70FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#CC2563EB"/>
        <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#DD3B82F6"/>
        <SolidColorBrush x:Key="PrimaryButtonPressedBrush" Color="#AA1D4ED8"/>
        <SolidColorBrush x:Key="PrimaryButtonTextBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="PrimaryButtonBorderBrush" Color="#802563EB"/>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#99000000"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0FF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryButtonTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#40DDDDDD"/>
                                <Setter Property="Foreground" Value="#66000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="#DD000000"/>
            <Setter Property="Background" Value="{StaticResource ControlSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="#24000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PanelSurfaceBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#66000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransparentTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Background="Transparent"/>
                            <ContentPresenter Grid.Row="1"
                                              ContentSource="SelectedContent"
                                              Margin="{TemplateBinding Padding}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransparentTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#CC000000"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="HeaderBorder"
                                Background="{StaticResource ControlSurfaceBrush}"
                                BorderBrush="#20000000"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{StaticResource PanelSurfaceBrush}"/>
                                <Setter Property="Foreground" Value="#F0000000"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{StaticResource ControlHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowChromeBorder"
            CornerRadius="12"
            Background="{StaticResource ChromeSurfaceBrush}"
            BorderBrush="#30000000"
            BorderThickness="1"
            Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12" Background="Transparent">
                <TextBlock Text="GhostPaste"
                           Foreground="#DD000000"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="完全透明"
                               Foreground="#88000000"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                    <Slider x:Name="UiOpacitySlider"
                            Width="130"
                            Minimum="0"
                            Maximum="100"
                            Value="100"
                            Margin="8,0"
                            VerticalAlignment="Center"
                            ValueChanged="UiOpacitySlider_ValueChanged"/>
                    <TextBlock Text="清晰"
                               Foreground="#88000000"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="?"
                            Click="AboutButton_Click"
                            Style="{StaticResource CloseButtonStyle}"/>
                    <Button Content="X"
                            Margin="4,0,0,0"
                            Click="CloseButton_Click"
                            Style="{StaticResource CloseButtonStyle}"/>
                </StackPanel>
            </Grid>

            <TabControl Grid.Row="1"
                        Style="{StaticResource TransparentTabControlStyle}"
                        ItemContainerStyle="{StaticResource TransparentTabItemStyle}">
                <TabItem Header="粘贴发送"
                         Style="{StaticResource TransparentTabItemStyle}">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0"
                                 x:Name="InputBox"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="14"
                                 Foreground="#EE000000"
                                 CaretBrush="#AA000000"
                                 Background="{StaticResource PanelSurfaceBrush}"
                                 BorderBrush="#20000000"
                                 BorderThickness="1"
                                 Padding="10,8"
                                 VerticalContentAlignment="Top">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>

                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="极速"
                                       Foreground="#99000000" FontSize="11"
                                       VerticalAlignment="Center"/>
                            <Slider Grid.Column="1"
                                    x:Name="SpeedSlider"
                                    Minimum="0" Maximum="120"
                                    Value="10"
                                    Margin="10,0"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="拟人"
                                       Foreground="#99000000" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Button Grid.Row="2"
                                x:Name="SendButton"
                                Content="发 送"
                                Click="SendButton_Click"
                                Margin="0,12,0,0"
                                Height="38"
                                FontSize="14" FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryButtonTextBrush}"
                                BorderBrush="{StaticResource PrimaryButtonBorderBrush}"
                                Background="{StaticResource PrimaryButtonBrush}"
                                Style="{StaticResource SendButtonStyle}"/>
                    </Grid>
                </TabItem>

                <TabItem Header="AI问答"
                         Style="{StaticResource TransparentTabItemStyle}">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0"
                                 x:Name="AiPromptBox"
                                 Height="96"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="13"
                                 Foreground="#EE000000"
                                 CaretBrush="#AA000000"
                                 Background="{StaticResource PanelSurfaceBrush}"
                                 BorderBrush="#20000000"
                                 BorderThickness="1"
                                 Padding="10,8"
                                 VerticalContentAlignment="Top"/>

                        <StackPanel Grid.Row="1" Margin="0,10,0,10">
                            <WrapPanel>
                                <Button x:Name="FullScreenCaptureButton"
                                        Content="全屏截图"
                                        Click="FullScreenCaptureButton_Click"
                                        Background="{StaticResource ControlSurfaceBrush}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"/>
                                <Button x:Name="TargetWindowCaptureButton"
                                        Content="目标窗口截图"
                                        Click="TargetWindowCaptureButton_Click"
                                        Background="{StaticResource ControlSurfaceBrush}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"/>
                                <Button x:Name="PrintWindowCaptureButton"
                                        Content="PrintWindow截图"
                                        Click="PrintWindowCaptureButton_Click"
                                        Background="{StaticResource ControlSurfaceBrush}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"/>
                            </WrapPanel>
                            <TextBlock x:Name="AttachmentStatusText"
                                       Text="未添加截图"
                                       Foreground="#99000000"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <RichTextBox Grid.Row="2"
                                     x:Name="AiMarkdownViewer"
                                     IsReadOnly="True"
                                     IsDocumentEnabled="True"
                                     VerticalScrollBarVisibility="Auto"
                                     FontSize="13"
                                     Foreground="#EE000000"
                                     Background="{StaticResource AnswerSurfaceBrush}"
                                     BorderBrush="#20000000"
                                     BorderThickness="1"
                                     Padding="10,8">
                            <RichTextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </RichTextBox.Resources>
                        </RichTextBox>

                        <Button Grid.Row="3"
                                x:Name="AiSendButton"
                                Content="发送给 AI"
                                Click="AiSendButton_Click"
                                Margin="0,12,0,0"
                                Height="38"
                                FontSize="14" FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryButtonTextBrush}"
                                BorderBrush="{StaticResource PrimaryButtonBorderBrush}"
                                Background="{StaticResource PrimaryButtonBrush}"
                                Style="{StaticResource SendButtonStyle}"/>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
