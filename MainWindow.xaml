<Window x:Class="GhostPaste.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GhostPaste"
        Width="560" Height="640"
        MinWidth="480" MinHeight="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <SolidColorBrush x:Key="ChromeSurfaceBrush" Color="#40FFFFFF"/>
        <SolidColorBrush x:Key="PanelSurfaceBrush" Color="#60FFFFFF"/>
        <SolidColorBrush x:Key="AnswerSurfaceBrush" Color="#50FFFFFF"/>
        <SolidColorBrush x:Key="ControlSurfaceBrush" Color="#50FFFFFF"/>
        <SolidColorBrush x:Key="ControlHoverBrush" Color="#70FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#CC2563EB"/>
        <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#DD3B82F6"/>
        <SolidColorBrush x:Key="PrimaryButtonPressedBrush" Color="#AA1D4ED8"/>
        <SolidColorBrush x:Key="PrimaryButtonTextBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="PrimaryButtonBorderBrush" Color="#802563EB"/>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#99000000"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0FF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#40DDDDDD"/>
                                <Setter Property="Foreground" Value="#66000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="#DD000000"/>
            <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="#24000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PanelSurfaceBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#66000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransparentTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Background="Transparent"/>
                            <ContentPresenter Grid.Row="1"
                                              ContentSource="SelectedContent"
                                              Margin="{TemplateBinding Padding}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransparentTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#CC000000"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="HeaderBorder"
                                Background="{DynamicResource ControlSurfaceBrush}"
                                BorderBrush="#20000000"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource PanelSurfaceBrush}"/>
                                <Setter Property="Foreground" Value="#F0000000"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource ControlHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecordCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="#22000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <DataTemplate x:Key="BoardRecordTemplate">
            <Border Style="{StaticResource RecordCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding TimeLabel}"
                               Foreground="#88000000"
                               FontSize="11"
                               Margin="0,0,0,6"/>

                    <Image Grid.Row="1"
                           Source="{Binding PreviewImage}"
                           Visibility="{Binding ImageVisibility}"
                           MaxHeight="120"
                           Stretch="Uniform"
                           HorizontalAlignment="Left"
                           Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="2"
                               Text="{Binding Text}"
                               Visibility="{Binding TextVisibility}"
                               Foreground="#E6000000"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>

                    <WrapPanel Grid.Row="3">
                        <TextBlock Text="{Binding ImageSummary}"
                                   Visibility="{Binding ImageVisibility}"
                                   Foreground="#88000000"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,6"/>
                        <Button Content="复制文本"
                                Tag="{Binding}"
                                Click="CopyBoardTextButton_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,6"/>
                        <Button Content="复制图片"
                                Tag="{Binding}"
                                Click="CopyBoardImageButton_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,6"/>
                        <Button Content="填入 AI"
                                Tag="{Binding}"
                                Click="UseBoardRecordForAiButton_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,6"/>
                        <Button Content="删除"
                                Tag="{Binding}"
                                Click="DeleteBoardRecordButton_Click"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,8,6"/>
                    </WrapPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border x:Name="WindowChromeBorder"
            CornerRadius="12"
            Background="{DynamicResource ChromeSurfaceBrush}"
            BorderBrush="#30000000"
            BorderThickness="1"
            Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12" Background="Transparent">
                <TextBlock Text="GhostPaste"
                           Foreground="#DD000000"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="完全透明"
                               Foreground="#88000000"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                    <Slider x:Name="UiOpacitySlider"
                            Width="130"
                            Minimum="0"
                            Maximum="100"
                            Value="100"
                            Margin="8,0"
                            VerticalAlignment="Center"
                            ValueChanged="UiOpacitySlider_ValueChanged"/>
                    <TextBlock Text="清晰"
                               Foreground="#88000000"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="?"
                            Click="AboutButton_Click"
                            Style="{StaticResource CloseButtonStyle}"/>
                    <Button Content="X"
                            Margin="4,0,0,0"
                            Click="CloseButton_Click"
                            Style="{StaticResource CloseButtonStyle}"/>
                </StackPanel>
            </Grid>

            <TabControl Grid.Row="1"
                        x:Name="MainTabControl"
                        Style="{StaticResource TransparentTabControlStyle}"
                        ItemContainerStyle="{StaticResource TransparentTabItemStyle}">
                <TabItem Header="粘贴发送"
                         Style="{StaticResource TransparentTabItemStyle}">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0"
                                 x:Name="InputBox"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="14"
                                 Foreground="#EE000000"
                                 CaretBrush="#AA000000"
                                 Background="{DynamicResource PanelSurfaceBrush}"
                                 BorderBrush="#20000000"
                                 BorderThickness="1"
                                 Padding="10,8"
                                 VerticalContentAlignment="Top">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>

                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="极速"
                                       Foreground="#99000000" FontSize="11"
                                       VerticalAlignment="Center"/>
                            <Slider Grid.Column="1"
                                    x:Name="SpeedSlider"
                                    Minimum="0" Maximum="120"
                                    Value="10"
                                    Margin="10,0"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="拟人"
                                       Foreground="#99000000" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Button Grid.Row="2"
                                x:Name="SendButton"
                                Content="发 送"
                                Click="SendButton_Click"
                                Margin="0,12,0,0"
                                Height="38"
                                FontSize="14" FontWeight="SemiBold"
                                Foreground="{DynamicResource PrimaryButtonTextBrush}"
                                BorderBrush="{DynamicResource PrimaryButtonBorderBrush}"
                                Background="{DynamicResource PrimaryButtonBrush}"
                                Style="{StaticResource SendButtonStyle}"/>
                    </Grid>
                </TabItem>

                <TabItem Header="AI问答"
                         Style="{StaticResource TransparentTabItemStyle}">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0"
                                 x:Name="AiPromptBox"
                                 Height="96"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="13"
                                 Foreground="#EE000000"
                                 CaretBrush="#AA000000"
                                 Background="{DynamicResource PanelSurfaceBrush}"
                                 BorderBrush="#20000000"
                                 BorderThickness="1"
                                 Padding="10,8"
                                 VerticalContentAlignment="Top"/>

                        <StackPanel Grid.Row="1" Margin="0,10,0,10">
                            <WrapPanel>
                                <Button x:Name="FullScreenCaptureButton"
                                        Content="全屏截图"
                                        Click="FullScreenCaptureButton_Click"
                                        Background="{DynamicResource ControlSurfaceBrush}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"/>
                                <Button x:Name="TargetWindowCaptureButton"
                                        Content="目标窗口截图"
                                        Click="TargetWindowCaptureButton_Click"
                                        Background="{DynamicResource ControlSurfaceBrush}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"/>
                                <Button x:Name="PrintWindowCaptureButton"
                                        Content="PrintWindow截图"
                                        Click="PrintWindowCaptureButton_Click"
                                        Background="{DynamicResource ControlSurfaceBrush}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"/>
                            </WrapPanel>
                            <TextBlock x:Name="AttachmentStatusText"
                                       Text="未添加截图"
                                       Foreground="#99000000"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                            <Border x:Name="AttachmentPreviewPanel"
                                    Visibility="Collapsed"
                                    Background="{DynamicResource ControlSurfaceBrush}"
                                    BorderBrush="#22000000"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8"
                                    Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Image x:Name="AttachmentPreviewImage"
                                           Grid.Column="0"
                                           Width="86"
                                           Height="58"
                                           Stretch="Uniform"
                                           Margin="0,0,10,0"/>

                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center">
                                        <TextBlock x:Name="AttachmentPreviewTitle"
                                                   Text="已添加图片"
                                                   FontWeight="SemiBold"
                                                   Foreground="#DD000000"/>
                                        <TextBlock x:Name="AttachmentPreviewMeta"
                                                   Foreground="#88000000"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <WrapPanel Grid.Column="2"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right">
                                        <Button x:Name="CropAttachmentButton"
                                                Content="裁切"
                                                Click="CropAttachmentButton_Click"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="0,0,8,0"/>
                                        <Button x:Name="SaveAttachmentToBoardButton"
                                                Content="存到记录板"
                                                Click="SaveAttachmentToBoardButton_Click"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="0,0,8,0"/>
                                        <Button x:Name="ClearAttachmentButton"
                                                Content="清除"
                                                Click="ClearAttachmentButton_Click"
                                                Style="{StaticResource SecondaryButtonStyle}"/>
                                    </WrapPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <RichTextBox Grid.Row="2"
                                     x:Name="AiMarkdownViewer"
                                     IsReadOnly="True"
                                     IsDocumentEnabled="True"
                                     VerticalScrollBarVisibility="Auto"
                                     FontSize="13"
                                     Foreground="#EE000000"
                                     Background="{DynamicResource AnswerSurfaceBrush}"
                                     BorderBrush="#20000000"
                                     BorderThickness="1"
                                     Padding="10,8">
                            <RichTextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </RichTextBox.Resources>
                        </RichTextBox>

                        <Button Grid.Row="3"
                                x:Name="AiSendButton"
                                Content="发送给 AI"
                                Click="AiSendButton_Click"
                                Margin="0,12,0,0"
                                Height="38"
                                FontSize="14" FontWeight="SemiBold"
                                Foreground="{DynamicResource PrimaryButtonTextBrush}"
                                BorderBrush="{DynamicResource PrimaryButtonBorderBrush}"
                                Background="{DynamicResource PrimaryButtonBrush}"
                                Style="{StaticResource SendButtonStyle}"/>
                    </Grid>
                </TabItem>
                <TabItem Header="记录板"
                         Style="{StaticResource TransparentTabItemStyle}">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0"
                                 x:Name="BoardInputBox"
                                 Height="82"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="13"
                                 Foreground="#EE000000"
                                 CaretBrush="#AA000000"
                                 Background="{DynamicResource PanelSurfaceBrush}"
                                 BorderBrush="#20000000"
                                 BorderThickness="1"
                                 Padding="10,8"
                                 VerticalContentAlignment="Top"/>

                        <WrapPanel Grid.Row="1"
                                   Margin="0,10,0,8">
                            <Button x:Name="AddBoardRecordButton"
                                    Content="添加记录"
                                    Click="AddBoardRecordButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,8,8"/>
                            <Button Content="添加当前图片"
                                    Click="SaveAttachmentToBoardButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,8,8"/>
                            <Button x:Name="PasteClipboardImageButton"
                                    Content="粘贴图片"
                                    Click="PasteClipboardImageButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,8,8"/>
                            <Button Content="清空记录"
                                    Click="ClearBoardButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,8,8"/>
                            <TextBlock x:Name="BoardStatusText"
                                       Text="记录只保存在本次打开期间"
                                       Foreground="#99000000"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,8"/>
                        </WrapPanel>

                        <ListBox Grid.Row="2"
                                 x:Name="BoardRecordsList"
                                 ItemTemplate="{StaticResource BoardRecordTemplate}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
