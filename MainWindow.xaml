<Window x:Class="GhostPaste.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GhostPaste"
        Width="420" Height="340"
        MinHeight="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
        
    <Window.Resources>
        <!-- Close button style -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#99000000"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0FF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Send button style -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#CC2563EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#DD3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#AA1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#40DDDDDD"/>
                                <Setter Property="Foreground" Value="#66000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Light theme acrylic border -->
    <Border CornerRadius="12"
            Background="#40FFFFFF"
            BorderBrush="#30000000"
            BorderThickness="1"
            Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Margin="0,0,0,12" Background="Transparent">
                <TextBlock Text="👻 GhostPaste"
                           Foreground="#DD000000"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Content="✕"
                        HorizontalAlignment="Right"
                        Click="CloseButton_Click"
                        Style="{StaticResource CloseButtonStyle}"/>
            </Grid>

            <!-- Text input -->
            <TextBox Grid.Row="1"
                     x:Name="InputBox"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontSize="14"
                     Foreground="#EE000000"
                     CaretBrush="#AA000000"
                     Background="#60FFFFFF"
                     BorderBrush="#20000000"
                     BorderThickness="1"
                     Padding="10,8"
                     VerticalContentAlignment="Top">
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>

            <!-- Speed slider -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="⚡极速"
                           Foreground="#99000000" FontSize="11"
                           VerticalAlignment="Center"/>
                <Slider Grid.Column="1"
                        x:Name="SpeedSlider"
                        Minimum="0" Maximum="120"
                        Value="10"
                        Margin="10,0"
                        VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="🐢拟人"
                           Foreground="#99000000" FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Send button -->
            <Button Grid.Row="3"
                    x:Name="SendButton"
                    Content="发 送"
                    Click="SendButton_Click"
                    Margin="0,12,0,0"
                    Height="38"
                    FontSize="14" FontWeight="SemiBold"
                    Foreground="White"
                    Cursor="Hand"
                    Style="{StaticResource SendButtonStyle}"/>
        </Grid>
    </Border>
</Window>
